@startuml Diagrama_de_Implantacao_Meritum_Refinado

skinparam style strictuml
skinparam componentStyle uml2

skinparam node {
    BackgroundColor #F8F9FA
    BorderColor #343A40
}

actor "Usuário" as User

node "Client Tier (Dispositivo)" #FFFFFF {
    component "Navegador (Browser)" as Browser
}

node "Edge Layer (Vercel CDN)" #LightBlue {
    artifact "React SPA (JS/CSS)" as SPA
    interface "HTTPS" as CDN_IF
}

node "Application Layer (Render Cloud)" #LightGreen {

    node "API Layer (Sync)" {
        component "Spring Boot API" as API
    }

    node "Async Processing" {
        component "Resgate Worker (Consumer)" as Worker
    }

    node "Persistence Layer" {
        database "PostgreSQL" as DB
    }
}

node "Messaging (CloudAMQP)" #LightGray {
    queue "RabbitMQ Queue\n(vantagens.resgate.queue)" as Fila
}

node "External Services" #F5F5F5 {
    component "ViaCEP API" as ViaCEP
}

node "Observability" #FFF3CD {
    component "Logs / Monitoring" as Logs
}

' --- RELAÇÕES ---

User --> Browser : Usa aplicação

Browser --> CDN_IF : HTTPS Request
CDN_IF --> SPA : Entrega arquivos estáticos

SPA --> API : REST (JSON)
SPA --> ViaCEP : GET /cep

API --> DB : JDBC / Connection Pool

API --> Fila : Publish (AMQP)
Fila --> Worker : Consume (RabbitMQ)

Worker --> DB : Transações

API --> Logs : Logs / Métricas
Worker --> Logs : Logs / Métricas

@enduml